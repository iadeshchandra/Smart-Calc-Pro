<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bgDark">

    <!-- TOP BAR -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="8dp" android:paddingEnd="16dp"
        android:background="@color/bgCard">
        <com.google.android.material.button.MaterialButton android:id="@+id/btnBack"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="48dp" android:layout_height="48dp"
            android:text="‹" android:textSize="24sp" android:textColor="@color/textPrimary"
            app:cornerRadius="24dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="🔬  Scientific Calculator"
            android:textSize="17sp" android:textStyle="bold" android:textColor="@color/textPrimary"/>
    </LinearLayout>

    <!-- DISPLAY -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="vertical" android:gravity="bottom"
        android:padding="16dp" android:background="@color/bgCard">
        <TextView android:id="@+id/tvExpression" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="" android:textSize="15sp"
            android:textColor="@color/textMuted" android:gravity="end"
            android:singleLine="true" android:ellipsize="start"/>
        <TextView android:id="@+id/tvDisplay" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="0" android:textSize="38sp"
            android:textColor="@color/textPrimary" android:gravity="end"
            android:singleLine="true" android:ellipsize="start" android:fontFamily="monospace"/>
    </LinearLayout>

    <!-- SCIENTIFIC BUTTONS (scrollable) -->
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="2" android:background="@color/bgDark">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="6dp">

            <!-- Row: Trig -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnSin"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="sin"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnCos"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="cos"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnTan"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="tan"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnAsin"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="sin⁻¹"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnAcos"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="cos⁻¹"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnAtan"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="tan⁻¹"/>
            </LinearLayout>

            <!-- Row: Hyperbolic -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnSinh"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="sinh"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnCosh"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="cosh"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnTanh"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="tanh"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnLog"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="log₁₀"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnLn"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="ln"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnLog2"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="log₂"/>
            </LinearLayout>

            <!-- Row: Power / Root -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnSqrt"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="√x"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnCbrt"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="∛x"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnPow"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="xʸ"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnPow2"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="x²"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnPow3"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="x³"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnExp"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="eˣ"/>
            </LinearLayout>

            <!-- Row: Misc functions -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnAbs"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="|x|"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnFact"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="n!"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnFloor"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="⌊x⌋"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnCeil"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="⌈x⌉"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnPi"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="π"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnE"
                    style="@style/SciButton" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="e"/>
            </LinearLayout>

            <!-- Row: Brackets + basic ops -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="60dp"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnOpenBr"
                    style="@style/CalcButtonOp" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="("/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnCloseBr"
                    style="@style/CalcButtonOp" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text=")"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnPercent"
                    style="@style/CalcButtonOp" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="%"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnDel"
                    style="@style/CalcButtonOp" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="⌫"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnClear"
                    style="@style/CalcButtonClear" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="C"/>
            </LinearLayout>

            <!-- Row 7,8,9 / -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="64dp"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/btn7"
                    style="@style/CalcButtonNum" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="7"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn8"
                    style="@style/CalcButtonNum" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="8"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn9"
                    style="@style/CalcButtonNum" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="9"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnDiv"
                    style="@style/CalcButtonOp" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="÷"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMul"
                    style="@style/CalcButtonOp" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="×"/>
            </LinearLayout>

            <!-- Row 4,5,6 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="64dp"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/btn4"
                    style="@style/CalcButtonNum" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="4"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn5"
                    style="@style/CalcButtonNum" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="5"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn6"
                    style="@style/CalcButtonNum" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="6"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnMinus"
                    style="@style/CalcButtonOp" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="−"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnPlus"
                    style="@style/CalcButtonOp" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="+"/>
            </LinearLayout>

            <!-- Row 1,2,3 +/- = -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="64dp"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/btn1"
                    style="@style/CalcButtonNum" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="1"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn2"
                    style="@style/CalcButtonNum" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="2"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn3"
                    style="@style/CalcButtonNum" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="3"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnPlusMinus"
                    style="@style/CalcButtonOp" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="+/−"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnEqual"
                    style="@style/CalcButtonEqual" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="="/>
            </LinearLayout>

            <!-- Row 0 . -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="64dp"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/btn0"
                    style="@style/CalcButtonNum" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="2" android:text="0"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnDot"
                    style="@style/CalcButtonNum" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1" android:text="."/>
                <View android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="2"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
